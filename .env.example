# Copy to .env and fill in values: `cp .env.example .env`
# Note: the app reads these via std::env::var and does NOT auto-load .env.
# Either export them into the environment, or run with a loader (e.g. dotenvy).

# Port the HTTP server binds to (0.0.0.0:$PORT). Default: 3000
PORT=3000

# API gate: required for all /api/* routes. Clients send it as
# `Authorization: Bearer <key>` or the bare key. If unset, every
# /api/* request is rejected as unauthorized.
# Generate one with: openssl rand -hex 32
API_KEY=

# tracing/log filter (tracing_subscriber EnvFilter syntax). Default: info
RUST_LOG=info
